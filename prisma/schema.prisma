generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  student
  teacher
}

enum TxReason {
  muro
  liderazgo
  iniciativa
  ayuda
  canje
}

enum HelpMode {
  need
  offer
}

enum HelpStatus {
  open
  matched
  closed
}

enum ProductCategory {
  membresia
  cafeteria
  impresiones
  otros
}

enum RedemptionStatus {
  pending
  completed
  failed
}

model User {
  id            String        @id @default(cuid())
  name          String
  email         String        @unique
  emailVerified DateTime?
  image         String?
  role          Role          @default(student)
  createdAt     DateTime      @default(now())
  account       Account?
  txFrom        LedgerTx[]    @relation("TxFrom")
  txTo          LedgerTx[]    @relation("TxTo")
  helpPosts     HelpPost[]
  redemptions   Redemption[]
  sessions      Session[]
  oauthAccounts OAuthAccount[]
}

model Account {
  id      String @id @default(cuid())
  userId  String @unique
  balance Int    @default(0)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LedgerTx {
  id         String      @id @default(cuid())
  fromId     String?
  toId       String
  amount     Int
  reason     TxReason
  category   String?
  signature  String
  hash       String      @unique
  prevHash   String?
  createdAt  DateTime    @default(now())
  from       User?       @relation("TxFrom", fields: [fromId], references: [id])
  to         User        @relation("TxTo", fields: [toId], references: [id])
  redemption Redemption?
}

model HelpPost {
  id        String     @id @default(cuid())
  authorId  String
  mode      HelpMode
  subject   String
  title     String
  body      String
  reward    Int        @default(0)
  status    HelpStatus @default(open)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  author    User       @relation(fields: [authorId], references: [id])
}

model Product {
  id          String          @id @default(cuid())
  category    ProductCategory
  name        String
  priceCoins  Int
  stock       Int?
  imageUrl    String?
  active      Boolean         @default(true)
  createdAt   DateTime        @default(now())
  redemptions Redemption[]
}

model Redemption {
  id         String           @id @default(cuid())
  userId     String
  productId  String
  costCoins  Int
  ledgerTxId String           @unique
  status     RedemptionStatus @default(pending)
  createdAt  DateTime         @default(now())
  user       User             @relation(fields: [userId], references: [id])
  product    Product          @relation(fields: [productId], references: [id])
  ledgerTx   LedgerTx         @relation(fields: [ledgerTxId], references: [id])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OAuthAccount {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
