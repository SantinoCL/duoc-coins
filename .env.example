# Duoc Coins — copia a .env.local y completa

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth (next-auth v5)
AUTH_SECRET=genera-con-openssl-rand-base64-32

# OIDC institucional Duoc UC (o Microsoft Entra ID si Duoc usa Office 365)
DUOC_OIDC_ISSUER=
DUOC_OIDC_CLIENT_ID=
DUOC_OIDC_CLIENT_SECRET=

# Base de datos (PostgreSQL — usa Neon o Supabase para prod)
DATABASE_URL=postgresql://user:pass@localhost:5432/duoccoins

# Ledger — clave HMAC para firmar transacciones (NUNCA exponer al cliente)
LEDGER_SIGNING_KEY=genera-con-openssl-rand-hex-32
